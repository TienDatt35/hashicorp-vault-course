{
  "name": "Dev Environment",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "customizations": {
    "vscode": {
      "extensions": ["hashicorp.hcl"],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash"
      }
    }
  },
  "remoteEnv": {
    "VAULT_ADDR": "http://127.0.0.1:8200",
    "VAULT_TOKEN": "root"
  },
  // After the container starts, run Vault in dev mode
  "postStartCommand": "vault server -dev -dev-root-token-id=root &",

  // Skip setcap configuration in the container for Codespaces
  "containerEnv": {
    "SKIP_SETCAP": "true"
  },

  // Port forwarding for Vault
  "forwardPorts": [8200],
  "portsAttributes": {
    "8200": { "label": "Vault API", "onAutoForward": "silent" }
  }
}

{
  "name": "Dev Environment",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "hashicorp.hcl"
      ],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash"
      }
    }
  },
  "postStartCommand": "vault server -dev -dev-root-token-id=root -dev-listen-address=127.0.0.1:8200 &&",
  "forwardPorts": [8200],
  "portsAttributes": {
    "8200": { "label": "Vault API", "onAutoForward": "silent" }
  },
  "remoteEnv": {
    "VAULT_ADDR": "http://127.0.0.1:8200",
    "VAULT_TOKEN": "root"
  }
}

{
  "name": "Dev Environment",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "customizations": {
    "vscode": {
      "extensions": ["hashicorp.hcl"],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash"
      }
    }
  },
  "remoteEnv": {
    "VAULT_ADDR": "http://127.0.0.1:8200",
    "VAULT_TOKEN": "root"
  },
  // Chạy vault server trong dev mode
  "postStartCommand": "nohup vault server -dev -dev-root-token-id=root >/tmp/vault.log 2>&1 & sleep 3",

  // Forward port 8200 để truy cập Vault từ máy local
  "forwardPorts": [8200],
  "portsAttributes": {
    "8200": { "label": "Vault API", "onAutoForward": "silent" }
  }
}
